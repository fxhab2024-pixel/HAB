# ============================================================
# BCGSP - سیستم عامل هوش استراتژیک کسب‌وکار
# Environment Variables Template
# ============================================================
# Copy this file to .env.local and fill in your values
# For Vercel: Add these in Project Settings > Environment Variables

# ---- DATABASE (Required) ----
# For Vercel: Use Neon, Supabase, or Vercel Postgres
# Example Neon URL: postgresql://user:password@ep-xxx.region.aws.neon.tech/bcgsp?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/bcgsp?sslmode=require

# ---- AUTH (Required) ----
# Generate a secure secret: openssl rand -base64 32
AUTH_SECRET=your-secret-key-here

# ---- AI (Optional - has fallback responses) ----
# z-ai-web-dev-sdk works without API keys in Space-Z platform.
# For Vercel: Set ZAI_API_KEY if available, or the app uses fallback responses.
# ZAI_API_KEY=your-api-key-here
